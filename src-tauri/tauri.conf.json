{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Novaframe",
  "version": "0.1.0",
  "identifier": "com.novaframe.desktop.wallpaper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Novaframe Wallpaper",
        "url": "index.html?mode=main",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnBottom": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Novaframe Controls",
        "width": 40,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "url": "index.html?mode=settings"
      },
      {
        "label": "storefront",
        "title": "Novaframe Marketplace",
        "url": "https://www.novaframe.co.uk/explore?source=engine",
        "width": 1280,
        "height": 800,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPDATA/themes/**",
          "/Users/tdaeche/Novaframe-Wallpapers/**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": ["novaframe"]
    },
    "updater": {
      "endpoints": [
        "https://marketplace-backend-gamma.vercel.app/api/engine/updates/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5Mzg2QzgzQzJCMzI4NEEKUldSS0tMUENnMnc0YWRNSmh3MG9aZFpUZ1c4clRnNk5xYjh2QjltSTZNWXZqTDlkSVBwS0x4VVYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}